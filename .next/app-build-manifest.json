      "static/chunks/app/(app)/campaigns/page.js"
    ],
    "/api/campaigns/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/campaigns/route.js"
    ],
    "/api/dashboard/metrics/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/dashboard/metrics/route.js"
    ],
    "/api/campaigns/[id]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/campaigns/[id]/route.js"
    ],
    "/(app)/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/dashboard/page.js"
    ],
    "/api/sync/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/sync/route.js"
    ]
  }
}